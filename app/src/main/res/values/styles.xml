<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="NoInternetTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="roundedButton" parent="@style/Widget.AppCompat.Button.Colored">
        <item name="android:background">@drawable/button_pill</item>
        <item name="android:paddingLeft">@dimen/margin_small</item>
        <item name="android:paddingRight">@dimen/margin_small</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Theme.AurumProTrader" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <!-- Compatibility style -->
    <style name="ForexSignalBuySellType">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="ForexSignalBuySellType.AdAttribution">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">left</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">12sp</item>
        <item name="android:text">@string/ad_attribution</item>
        <item name="android:background">#FFCC66</item>
        <item name="android:width">15dp</item>
        <item name="android:height">15dp</item>
    </style>

    <style name="brokerRowStyle" parent="@android:style/Widget.TextView">
        <item name="android:textSize">@dimen/_12sdp</item>
        <item name="android:textColor">#ff1d1d1d</item>
        <item name="android:gravity">left|center_vertical</item>
        <item name="android:padding">5dp</item>
    </style>

    <style name="traparentdialog">
        <item name="android:windowBackground">@color/black_tran</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <color name="black_tran">#C1000000</color>
    <color name="gray">#c8c6c7</color>

    <style name="EditTextAppTheme1" parent="@android:style/Widget.EditText">
        <item name="android:textColorHint">@color/gray</item>
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/semibold</item>
        <item name="android:textSize">@dimen/_10sdp</item>
    </style>

    <style name="ActionBar">
        <item name="android:titleTextStyle">@style/TitleTextStyle</item>
    </style>

    <style name="TitleTextStyle" parent="@android:style/Widget.TextView">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="titleTextView" parent="@android:style/Widget.TextView">
        <item name="android:textSize">@dimen/_10sdp</item>
        <item name="android:textStyle">normal</item>
        <item name="fontFamily">@font/semibold</item>
        <item name="android:gravity">right|center_horizontal|clip_horizontal</item>
    </style>

    <style name="CustomButton3" parent="@android:style/Widget.Button">
        <item name="android:textSize">@dimen/_13sdp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">#000000</item>
        <item name="android:gravity">center</item>
        <item name="fontFamily">@font/bold</item>
        <item name="android:background">@drawable/selector_button3</item>
        <item name="android:padding">3dp</item>
        <item name="android:shadowColor">#000000</item>
    </style>

    <style name="textAppearance" parent="@android:style/TextAppearance.Small">
        <item name="android:textSize">@dimen/_14sdp</item>
        <item name="android:textColor">#ff1d1d1d</item>
    </style>

    <style name="settingsTitleText" parent="@android:style/Widget.TextView">
        <item name="android:textSize">@dimen/_12sdp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">left|center_horizontal|clip_horizontal</item>
    </style>

</resources>
